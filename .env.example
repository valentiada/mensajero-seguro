# PostgreSQL (основний варіант)
DATABASE_URL=postgresql://user:password@localhost:5432/weego_messenger

# Або залиште порожнім для SQLite (файл database/messenger.db)
# DATABASE_URL=

# Секрет для сесій та токенів
SECRET_KEY=your-secret-key-min-32-chars

# Ключі шифрування повідомлень (Fernet, urlsafe base64, 32-byte).
# Можна вказати кілька ключів через кому для ротації.
MESSENGER_ENCRYPTION_KEYS=

# Таймаут очікування відповіді на дзвінок (сек), мінімум 15
CALL_PENDING_TIMEOUT_SECONDS=45

# ICE сервери для WebRTC (JSON-масив)
ICE_SERVERS=

# TURN сервери (альтернатива JSON формату)
TURN_URLS=
TURN_USERNAME=
TURN_CREDENTIAL=

# Час життя токена (години)
TOKEN_TTL_HOURS=720

# Режим відлагодження (1 або 0)
DEBUG=1

# Базовий шлях на сайті
# BASE_PATH=/messenger

# VAPID ключі для Web Push
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_CLAIMS_EMAIL=admin@example.com

# Максимальний розмір вкладення (байти), 0 = вимкнено
MAX_ATTACHMENT_BYTES=10485760

# Порогові значення rate-limit
AUTH_LOGIN_RATE_LIMIT=12
AUTH_REGISTER_RATE_LIMIT=8
AUTH_RATE_WINDOW_SECONDS=60
